# =====================================================
# SUPABASE
# =====================================================
# Obtenha essas credenciais em: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# =====================================================
# TWILIO (WhatsApp)
# =====================================================
# Pode ser configurado via UI em /admin/settings
# Ou via variáveis de ambiente (fallback)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# Content SIDs para templates aprovados do WhatsApp (check-ins de gamificação)
TWILIO_CHECKIN_WATER_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CHECKIN_BREAKFAST_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CHECKIN_LUNCH_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CHECKIN_DINNER_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CHECKIN_SNACKS_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CHECKIN_ACTIVITY_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CHECKIN_WELLBEING_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CHECKIN_WEIGHT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Template genérico para mensagens de conteúdo de protocolo (dicas, reflexões, planejamento)
# Sem isso, mensagens proativas falham fora da janela de 24h do WhatsApp (erro 63016)
# Formato esperado: "Olá {{1}}! 👋\n\n{{2}}" onde {{1}}=nome, {{2}}=conteúdo
TWILIO_PROTOCOL_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Template de upgrade de plano — enviado quando admin muda paciente para premium/vip
# Se não configurado, usa TWILIO_PROTOCOL_INCENTIVO_SID como fallback
# Formato sugerido: "{{1}} Boa notícia, {{2}}! Seu plano foi atualizado para *{{3}}*..." ({{1}}=emoji, {{2}}=nome, {{3}}=plano... ajuste conforme seu template aprovado)
# Variáveis com TWILIO_PLAN_UPGRADE_SID: {"1": nome, "2": "💎 Premium", "3": protocolo}
# Variáveis com fallback (TWILIO_PROTOCOL_INCENTIVO_SID): {"1": nome, "2": mensagem completa}
TWILIO_PLAN_UPGRADE_SID=

# =====================================================
# CRON JOB & TIMEZONE
# =====================================================
# Segredo para proteger endpoints de cron
CRON_SECRET=CuidarMeCronSecret123

# Timezone para agendamento de mensagens (padrão: America/Sao_Paulo)
TZ=America/Sao_Paulo

# =====================================================
# GOOGLE GEMINI (IA)
# =====================================================
# Para os fluxos de IA e classificação de mensagens
# Obtenha em: https://makersuite.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_gemini_api_key
